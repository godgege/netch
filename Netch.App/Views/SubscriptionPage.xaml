<Page
    x:Class="Netch.App.Views.SubscriptionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Subscriptions" Style="{StaticResource TitleTextBlockStyle}" />

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.Subscriptions}"
                  SelectedItem="{x:Bind ViewModel.SelectedSubscription, Mode=TwoWay}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Remark}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="{Binding Link}" Foreground="Gray" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="2" Spacing="8">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" PlaceholderText="Remark" Text="{x:Bind ViewModel.Remark, Mode=TwoWay}" />
                <TextBox Grid.Column="1" PlaceholderText="URL" Text="{x:Bind ViewModel.Link, Mode=TwoWay}" />
                <TextBox Grid.Column="2" PlaceholderText="User Agent" Text="{x:Bind ViewModel.UserAgent, Mode=TwoWay}" />
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Add" Command="{x:Bind ViewModel.AddCommand}" />
                <Button Content="Delete" Command="{x:Bind ViewModel.DeleteCommand}" />
                <Button Content="Update All" Command="{x:Bind ViewModel.UpdateAllCommand}" Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>

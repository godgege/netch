<Page
    x:Class="Netch.App.Views.LogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16">
            <TextBlock Text="Log" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            <ToggleSwitch Header="All Process Events"
                          IsOn="{x:Bind ViewModel.ShowAllProcessEvents, Mode=TwoWay}" />
        </StackPanel>

        <ScrollViewer x:Name="LogScrollViewer"
                      Grid.Row="1"
                      Padding="0,4"
                      ViewChanged="LogScrollViewer_ViewChanged">
            <ItemsControl ItemsSource="{x:Bind ViewModel.VisibleLogEntries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{x:Bind}" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" Margin="0,2" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>

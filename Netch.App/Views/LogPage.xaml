<Page
    x:Class="Netch.App.Views.LogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16">
            <TextBlock Text="Log" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            <ToggleSwitch Header="Auto Scroll" IsOn="{x:Bind ViewModel.AutoScroll, Mode=TwoWay}" />
        </StackPanel>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.LogEntries}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <TextBlock Text="{x:Bind}" FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

<Window
    x:Class="Netch.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <NavigationView x:Name="NavView"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="False"
                    PaneDisplayMode="Top"
                    SelectionChanged="NavView_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="首页" Tag="MainPage" />
            <NavigationViewItem Content="模式" Tag="ModesPage" />
            <NavigationViewItem Content="订阅" Tag="SubscriptionPage" />
            <NavigationViewItem Content="日志" Tag="LogPage" />
            <NavigationViewItem Content="设置" Tag="SettingsPage" />
            <NavigationViewItem Content="关于" Tag="AboutPage" />
        </NavigationView.MenuItems>

        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Window>

<Window
    x:Class="Netch.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <NavigationView x:Name="NavView"
                    IsBackButtonVisible="Collapsed"
                    PaneDisplayMode="Left"
                    SelectionChanged="NavView_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Uid="NavHome" Tag="MainPage" />
            <NavigationViewItem x:Uid="NavModes" Tag="ModesPage" />
            <NavigationViewItem x:Uid="NavSubscriptions" Tag="SubscriptionPage" />
            <NavigationViewItem x:Uid="NavLog" Tag="LogPage" />
        </NavigationView.MenuItems>

        <NavigationView.FooterMenuItems>
            <NavigationViewItem x:Uid="NavSettings" Tag="SettingsPage" />
            <NavigationViewItem x:Uid="NavAbout" Tag="AboutPage" />
        </NavigationView.FooterMenuItems>

        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Window>

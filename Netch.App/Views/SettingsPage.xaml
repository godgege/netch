<Page
    x:Class="Netch.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="SettingsPage_Loaded"
    SizeChanged="SettingsPage_SizeChanged">

    <Page.Resources>
        <Style x:Key="SettingsSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,8,0,2" />
        </Style>

        <Style x:Key="SettingsOptionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="SettingsOptionRowStyle" TargetType="Grid">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Margin" Value="20,0,0,0" />
            <Setter Property="ColumnSpacing" Value="14" />
        </Style>
    </Page.Resources>

    <ScrollViewer x:Name="SettingsScroll"
                  Padding="32,28,32,36"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled">
        <Grid x:Name="SettingsLayout"
              MaxWidth="920"
              HorizontalAlignment="Stretch"
              ColumnSpacing="44"
              RowSpacing="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="HeaderSection"
                        Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="2">
                <TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>

            <StackPanel x:Name="AppearanceSection"
                        Grid.Row="1"
                        Grid.Column="0"
                        Spacing="10">
                <TextBlock Text="外观" Style="{StaticResource SettingsSectionTitleStyle}" />

                <Grid Tag="SettingRow" Style="{StaticResource SettingsOptionRowStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="主题" Style="{StaticResource SettingsOptionLabelStyle}" />
                    <ComboBox Grid.Row="0" Grid.Column="1"
                              Tag="ThemeInput"
                              Width="150"
                              HorizontalAlignment="Left"
                              SelectedIndex="{x:Bind ViewModel.ThemeIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="跟随系统" />
                        <ComboBoxItem Content="浅色" />
                        <ComboBoxItem Content="深色" />
                    </ComboBox>
                </Grid>
            </StackPanel>

            <StackPanel x:Name="ProxySection"
                        Grid.Row="2"
                        Grid.Column="0"
                        Spacing="10">
                <TextBlock Text="代理" Style="{StaticResource SettingsSectionTitleStyle}" />

                <Grid Tag="SettingRow" Style="{StaticResource SettingsOptionRowStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="SOCKS5 端口" Style="{StaticResource SettingsOptionLabelStyle}" />
                    <NumberBox Grid.Row="0" Grid.Column="1"
                               Tag="NumberInput"
                               Width="160"
                               HorizontalAlignment="Left"
                               Value="{x:Bind ViewModel.Socks5LocalPort, Mode=TwoWay}"
                               Minimum="1"
                               Maximum="65535" />
                </Grid>

                <Grid Tag="SettingRow" Style="{StaticResource SettingsOptionRowStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="允许其他设备连接" Style="{StaticResource SettingsOptionLabelStyle}" />
                    <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                  Tag="SwitchInput"
                                  HorizontalAlignment="Left"
                                  IsOn="{x:Bind ViewModel.AllowDevices, Mode=TwoWay}" />
                </Grid>

                <Grid Tag="SettingRow" Style="{StaticResource SettingsOptionRowStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="使用 TCP Ping" Style="{StaticResource SettingsOptionLabelStyle}" />
                    <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                  Tag="SwitchInput"
                                  HorizontalAlignment="Left"
                                  IsOn="{x:Bind ViewModel.ServerTCPing, Mode=TwoWay}" />
                </Grid>

                <Grid Tag="SettingRow" Style="{StaticResource SettingsOptionRowStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="配置数量" Style="{StaticResource SettingsOptionLabelStyle}" />
                    <NumberBox Grid.Row="0" Grid.Column="1"
                               Tag="NumberInput"
                               Width="160"
                               HorizontalAlignment="Left"
                               Value="{x:Bind ViewModel.ProfileCount, Mode=TwoWay}"
                               Minimum="0"
                               Maximum="20" />
                </Grid>

                <Grid Tag="SettingRow" Style="{StaticResource SettingsOptionRowStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="检测间隔（秒）" Style="{StaticResource SettingsOptionLabelStyle}" />
                    <NumberBox Grid.Row="0" Grid.Column="1"
                               Tag="NumberInput"
                               Width="160"
                               HorizontalAlignment="Left"
                               Value="{x:Bind ViewModel.DetectionTick, Mode=TwoWay}" />
                </Grid>

                <Grid Tag="SettingRow" Style="{StaticResource SettingsOptionRowStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="STUN 服务器" Style="{StaticResource SettingsOptionLabelStyle}" />
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Tag="LongInput"
                             Width="220"
                             HorizontalAlignment="Left"
                             Text="{x:Bind ViewModel.StunServer, Mode=TwoWay}" />
                </Grid>
            </StackPanel>

            <StackPanel x:Name="StartupSection"
                        Grid.Row="1"
                        Grid.Column="1"
                        Spacing="10">
                <TextBlock Text="启动和退出" Style="{StaticResource SettingsSectionTitleStyle}" />

                <Grid Tag="SettingRow" Style="{StaticResource SettingsOptionRowStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="关闭窗口时退出" Style="{StaticResource SettingsOptionLabelStyle}" />
                    <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                  Tag="SwitchInput"
                                  HorizontalAlignment="Left"
                                  IsOn="{x:Bind ViewModel.ExitWhenClosed, Mode=TwoWay}" />
                </Grid>

                <Grid Tag="SettingRow" Style="{StaticResource SettingsOptionRowStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="退出时停止代理" Style="{StaticResource SettingsOptionLabelStyle}" />
                    <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                  Tag="SwitchInput"
                                  HorizontalAlignment="Left"
                                  IsOn="{x:Bind ViewModel.StopWhenExited, Mode=TwoWay}" />
                </Grid>

                <Grid Tag="SettingRow" Style="{StaticResource SettingsOptionRowStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="打开后自动启动" Style="{StaticResource SettingsOptionLabelStyle}" />
                    <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                  Tag="SwitchInput"
                                  HorizontalAlignment="Left"
                                  IsOn="{x:Bind ViewModel.StartWhenOpened, Mode=TwoWay}" />
                </Grid>

                <Grid Tag="SettingRow" Style="{StaticResource SettingsOptionRowStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="启动后最小化" Style="{StaticResource SettingsOptionLabelStyle}" />
                    <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                  Tag="SwitchInput"
                                  HorizontalAlignment="Left"
                                  IsOn="{x:Bind ViewModel.MinimizeWhenStarted, Mode=TwoWay}" />
                </Grid>

                <Grid Tag="SettingRow" Style="{StaticResource SettingsOptionRowStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="开机自启动" Style="{StaticResource SettingsOptionLabelStyle}" />
                    <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                  Tag="SwitchInput"
                                  HorizontalAlignment="Left"
                                  IsOn="{x:Bind ViewModel.RunAtStartup, Mode=TwoWay}" />
                </Grid>
            </StackPanel>

            <StackPanel x:Name="UpdatesSection"
                        Grid.Row="2"
                        Grid.Column="1"
                        Spacing="10">
                <TextBlock Text="更新" Style="{StaticResource SettingsSectionTitleStyle}" />

                <Grid Tag="SettingRow" Style="{StaticResource SettingsOptionRowStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="打开时检查更新" Style="{StaticResource SettingsOptionLabelStyle}" />
                    <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                  Tag="SwitchInput"
                                  HorizontalAlignment="Left"
                                  IsOn="{x:Bind ViewModel.CheckUpdateWhenOpened, Mode=TwoWay}" />
                </Grid>

                <Grid Tag="SettingRow" Style="{StaticResource SettingsOptionRowStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="检查测试版更新" Style="{StaticResource SettingsOptionLabelStyle}" />
                    <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                  Tag="SwitchInput"
                                  HorizontalAlignment="Left"
                                  IsOn="{x:Bind ViewModel.CheckBetaUpdate, Mode=TwoWay}" />
                </Grid>

                <Grid Tag="SettingRow" Style="{StaticResource SettingsOptionRowStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="打开时更新服务器" Style="{StaticResource SettingsOptionLabelStyle}" />
                    <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                  Tag="SwitchInput"
                                  HorizontalAlignment="Left"
                                  IsOn="{x:Bind ViewModel.UpdateServersWhenOpened, Mode=TwoWay}" />
                </Grid>
            </StackPanel>

            <Button x:Name="SaveButton"
                    Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Content="保存"
                    Command="{x:Bind ViewModel.SaveCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Left"
                    MinWidth="120" />
            <StackPanel x:Name="AboutSection"
                        Grid.Row="4"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Spacing="10">
                <TextBlock Text="关于" Style="{StaticResource SettingsSectionTitleStyle}" />

                <StackPanel Margin="20,0,0,0" Spacing="6">
                    <TextBlock Text="Netch" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="支持多协议的 Windows 代理客户端。"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="许可证：GPLv3"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <HyperlinkButton Content="GitHub"
                                     NavigateUri="https://github.com/netchx/netch"
                                     Padding="0"
                                     HorizontalAlignment="Left" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
<Page
    x:Class="Netch.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Netch.App.Models"
    IsTabStop="True">

    <Page.Resources>
        <Style x:Key="HomeSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="HomePaneTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HomeActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="30" />
        </Style>
    </Page.Resources>

    <Grid Padding="32,28,32,0" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="10">
            <TextBlock Text="代理" Style="{StaticResource HomeSectionTitleStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Bottom">
                <ComboBox Header="协议"
                          ItemsSource="{x:Bind ViewModel.ProxyProtocols}"
                          SelectedItem="{x:Bind ViewModel.SelectedProxyProtocol, Mode=TwoWay}"
                          IsEnabled="False"
                          Width="132" />
                <TextBox Header="代理地址"
                         PlaceholderText="代理地址"
                         Text="{x:Bind ViewModel.ProxyHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{x:Bind ViewModel.IsHostEditable, Mode=OneWay}"
                         Width="200" />
                <TextBox x:Name="PortBox"
                         Header="端口"
                         PlaceholderText="端口"
                         Text="{x:Bind ViewModel.ProxyPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="100" />
                <CheckBox Content="自动填写本地 (127.0.0.1)"
                          IsChecked="{x:Bind ViewModel.UseLocalhostOverride, Mode=TwoWay}"
                          VerticalAlignment="Bottom"
                          Margin="0,0,0,6" />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1"
                Height="1"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <Grid Grid.Row="2" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="应用规则" Style="{StaticResource HomeSectionTitleStyle}" />

            <Grid Grid.Row="1" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1.15*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="应用列表" Style="{StaticResource HomePaneTitleStyle}" />

                    <TextBox Grid.Row="1"
                             PlaceholderText="搜索应用..."
                             Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <ListView Grid.Row="2"
                              ItemsSource="{x:Bind ViewModel.FilteredApps}"
                              SelectionMode="None"
                              Padding="0"
                              Margin="0">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:InstalledApp">
                                <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                          Click="AppCheckBox_Click"
                                          Tag="{x:Bind}"
                                          ToolTipService.ToolTip="{x:Bind InstallPath}">
                                    <CheckBox.Content>
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind Name}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />
                                            <TextBlock Text="{x:Bind InstallPath}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />
                                        </StackPanel>
                                    </CheckBox.Content>
                                </CheckBox>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <Grid Grid.Column="1" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{x:Bind ViewModel.SelectedAppsTitle, Mode=OneWay}"
                               Style="{StaticResource HomePaneTitleStyle}" />

                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.ProcessGroups}"
                              SelectionMode="None"
                              Padding="0">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ProcessGroup">
                                <Grid Padding="0,8,0,10" RowSpacing="5">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind GroupName}"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Content="目录"
                                                Style="{StaticResource HomeActionButtonStyle}"
                                                ToolTipService.ToolTip="添加目录"
                                                Tag="{x:Bind}"
                                                Click="AddToGroup_Click" />
                                        <Button Grid.Column="2"
                                                Content="程序"
                                                Style="{StaticResource HomeActionButtonStyle}"
                                                ToolTipService.ToolTip="添加程序"
                                                Tag="{x:Bind}"
                                                Click="AddExeToGroup_Click" />
                                        <Button Grid.Column="3"
                                                Content="移除"
                                                Style="{StaticResource HomeActionButtonStyle}"
                                                ToolTipService.ToolTip="移除"
                                                Tag="{x:Bind}"
                                                Click="RemoveGroup_Click" />
                                    </Grid>

                                    <TextBlock Grid.Row="1"
                                               Text="{x:Bind DisplayText, Mode=OneWay}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               FontSize="12" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="3"
              MinHeight="56"
              Padding="0,8,0,8"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap" />

            <Button x:Name="StartStopButton"
                    Grid.Column="1"
                    Content="{x:Bind ViewModel.ControlButtonText, Mode=OneWay}"
                    Command="{x:Bind ViewModel.StartStopCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    MinWidth="120"
                    VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Page>
<Page
    x:Class="Netch.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Netch.App.Models"
    IsTabStop="True">

    <Grid Padding="32" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="12">
            <TextBlock x:Uid="ProxyTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox x:Uid="HostBox"
                         Text="{x:Bind ViewModel.ProxyHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{x:Bind ViewModel.IsHostEditable, Mode=OneWay}"
                         Width="200" />
                <TextBox x:Uid="PortBox" x:Name="PortBox"
                         Text="{x:Bind ViewModel.ProxyPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="100" />
                <CheckBox Content="自动填写本地 (127.0.0.1)"
                          IsChecked="{x:Bind ViewModel.UseLocalhostOverride, Mode=TwoWay}"
                          VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBox x:Uid="SearchBox"
                         Grid.Row="0"
                         Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <ListView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.FilteredApps}"
                          SelectionMode="None"
                          Padding="0"
                          Margin="0">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:InstalledApp">
                            <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                      Click="AppCheckBox_Click"
                                      Tag="{x:Bind}"
                                      ToolTipService.ToolTip="{x:Bind InstallPath}">
                                <CheckBox.Content>
                                    <StackPanel>
                                        <TextBlock Text="{x:Bind Name}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap" />
                                        <TextBlock Text="{x:Bind InstallPath}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap" />
                                    </StackPanel>
                                </CheckBox.Content>
                            </CheckBox>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Grid Grid.Column="1" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Uid="SelectedTitle" Grid.Row="0" Style="{StaticResource BodyStrongTextBlockStyle}" />

                <ListView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.ProcessGroups}"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ProcessGroup">
                            <Grid Padding="0,10" RowSpacing="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind GroupName}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Content="Add folder"
                                            Margin="4,0"
                                            Padding="8,5"
                                            ToolTipService.ToolTip="Add folder"
                                            Tag="{x:Bind}"
                                            Click="AddToGroup_Click" />
                                    <Button Grid.Column="2"
                                            Content="Add exe"
                                            Margin="4,0"
                                            Padding="8,5"
                                            ToolTipService.ToolTip="Add exe"
                                            Tag="{x:Bind}"
                                            Click="AddExeToGroup_Click" />
                                    <Button Grid.Column="3"
                                            Content="Remove"
                                            Padding="8,5"
                                            ToolTipService.ToolTip="Remove"
                                            Tag="{x:Bind}"
                                            Click="RemoveGroup_Click" />
                                </Grid>

                                <TextBlock Grid.Row="1"
                                           Text="{x:Bind DisplayText, Mode=OneWay}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           Margin="4,0,0,0" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <Grid Grid.Row="2"
              Padding="0,12,0,0"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap" />

            <Button x:Name="StartStopButton"
                    Grid.Column="1"
                    Content="{x:Bind ViewModel.ControlButtonText, Mode=OneWay}"
                    Command="{x:Bind ViewModel.StartStopCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    MinWidth="120" />
        </Grid>
    </Grid>
</Page>

